{%- comment -%}
  Testimonials section
{%- endcomment -%}

<section class="testimonials-section" id="testimonials">
  <div class="container">
    <div class="text-center animate-fade-up">
      <span class="section-eyebrow">{{ section.settings.eyebrow | default: 'Experiences' }}</span>
      <h2 class="section-title">{{ section.settings.title | default: 'What early testers say' }}</h2>
    </div>

    <div class="testimonials-grid">
      {% for block in section.blocks %}
        <div class="testimonial-card animate-fade-up" style="animation-delay: {{ forloop.index0 | times: 150 }}ms" {{ block.shopify_attributes }}>
          {%- comment -%} Stars {%- endcomment -%}
          <div class="testimonial-stars">
            {% for i in (1..5) %}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" class="star-icon"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {% endfor %}
          </div>

          <p class="testimonial-text">"{{ block.settings.text }}"</p>

          <div class="testimonial-author">
            <div class="testimonial-avatar">
              <span>{{ block.settings.name | slice: 0 }}</span>
            </div>
            <div>
              <div class="testimonial-name">{{ block.settings.name }}</div>
              {% if block.settings.verified %}
                <div class="testimonial-verified">
                  <svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                  {{ section.settings.verified_label | default: 'Early Tester' }}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Experiences"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What early testers say"
    },
    {
      "type": "text",
      "id": "verified_label",
      "label": "Verified label",
      "default": "Early Tester"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Lisa V."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial text",
          "default": "I was looking for something without caffeine that actually tastes good. This has become my regular evening moment."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "name": "Lisa V.", "text": "I was looking for something without caffeine that actually tastes good. This has become my regular evening moment.", "verified": true } },
        { "type": "testimonial", "settings": { "name": "Mark D.", "text": "Soft and nutty, very soothing. Exactly what I was looking for after a busy day.", "verified": true } },
        { "type": "testimonial", "settings": { "name": "Emma K.", "text": "Nice to have something warm to drink without it affecting my sleep.", "verified": true } }
      ]
    }
  ]
}
{% endschema %}
