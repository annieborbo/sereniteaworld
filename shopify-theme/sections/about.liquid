{%- comment -%}
  About section – What is Buckwheat Tea?
{%- endcomment -%}

<section class="about-section" id="about">
  <div class="about-bg-blob about-bg-blob-1"></div>
  <div class="about-bg-blob about-bg-blob-2"></div>

  <div class="container about-inner">
    <div class="about-content animate-fade-up">
      <h2 class="section-title">{{ section.settings.title | default: 'What is Buckwheat Tea?' }}</h2>

      <div class="about-text">
        <p>{{ section.settings.paragraph1 }}</p>
        <p>{{ section.settings.paragraph2 }}</p>
      </div>

      {%- comment -%} Benefit Icons {%- endcomment -%}
      <div class="benefits-grid">
        {% for block in section.blocks %}
          <div class="benefit-item">
            <div class="benefit-icon">
              {% if block.settings.icon == 'leaf' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 1c1 2 2 4.5 2 8 0 5.5-4.78 11-10 11Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
              {% elsif block.settings.icon == 'coffee' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 0 1 1 0 8h-1"/><path d="M6 2v2"/></svg>
              {% elsif block.settings.icon == 'cup' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 8 1.75 12.28a2 2 0 0 0 2 1.72h4.54a2 2 0 0 0 2-1.72L18 8"/><path d="M5 8h14"/><path d="M7 15a6.47 6.47 0 0 1 5 0 6.47 6.47 0 0 0 5 0"/><path d="m12 8 1-6h2"/></svg>
              {% elsif block.settings.icon == 'wheat' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22 16 8"/><path d="M3.47 12.53 5 11l1.53 1.53a3.5 3.5 0 0 1 0 4.94L5 19l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/><path d="M7.47 8.53 9 7l1.53 1.53a3.5 3.5 0 0 1 0 4.94L9 15l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/><path d="M11.47 4.53 13 3l1.53 1.53a3.5 3.5 0 0 1 0 4.94L13 11l-1.53-1.53a3.5 3.5 0 0 1 0-4.94Z"/><path d="M20 2h2v2a4 4 0 0 1-4 4h-2V6a4 4 0 0 1 4-4Z"/><path d="M11.47 17.47 13 19l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L5 19l1.53-1.53a3.5 3.5 0 0 1 4.94 0Z"/><path d="M15.47 13.47 17 15l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L9 15l1.53-1.53a3.5 3.5 0 0 1 4.94 0Z"/><path d="M19.47 9.47 21 11l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L13 11l1.53-1.53a3.5 3.5 0 0 1 4.94 0Z"/></svg>
              {% elsif block.settings.icon == 'sprout' %}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/></svg>
              {% endif %}
            </div>
            <span class="benefit-label">{{ block.settings.label }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "What is Buckwheat Tea?"
    },
    {
      "type": "textarea",
      "id": "paragraph1",
      "label": "Paragraph 1",
      "default": "Buckwheat tea is a caffeine-free drink made from roasted buckwheat seeds. The taste is soft, nutty and slightly sweet, often compared to cookies or grains."
    },
    {
      "type": "textarea",
      "id": "paragraph2",
      "label": "Paragraph 2",
      "default": "Because it contains no caffeine, it's suitable for drinking in the evening too. Just a warm or cold moment, without stimulants."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "coffee", "label": "Coffee cup" },
            { "value": "cup", "label": "Cup/Soda" },
            { "value": "wheat", "label": "Wheat" },
            { "value": "sprout", "label": "Sprout" }
          ],
          "default": "leaf"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "100% Natural"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About",
      "blocks": [
        { "type": "benefit", "settings": { "icon": "leaf", "label": "100% Natural" } },
        { "type": "benefit", "settings": { "icon": "coffee", "label": "Caffeine Free" } },
        { "type": "benefit", "settings": { "icon": "cup", "label": "Sugar Free" } },
        { "type": "benefit", "settings": { "icon": "wheat", "label": "Gluten Free" } },
        { "type": "benefit", "settings": { "icon": "sprout", "label": "Vegan" } }
      ]
    }
  ]
}
{% endschema %}
